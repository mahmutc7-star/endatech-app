generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Quote {
  id              String      @id @default(cuid())
  quoteNumber     String      @unique // Format: END-2026-XXXXX

  // Customer info
  name            String
  email           String
  phone           String
  address         String
  city            String
  postalCode      String

  // Property info
  propertyType    String      // Type woning/pand
  rooms           String      // Gewenste ruimte(s)
  photos          String[]    // URLs to uploaded photos
  notes           String?     // Extra opmerkingen

  // Quote details
  description     String?     // Quote description/content
  totalAmount     Decimal?    // Total price excl. BTW (auto-calculated)
  btwPercentage   Decimal     @default(21) // BTW percentage
  validUntil      DateTime?   // Quote validity date
  pdfUrl          String?     // Generated PDF URL

  // Line items
  lines           QuoteLine[]

  // Signature
  signed          Boolean     @default(false)
  signedAt        DateTime?
  signature       String?     // Base64 signature image
  signedIp        String?
  signedDevice    String?     // Device info JSON (browser, OS, screen, etc.)
  signedLocation  String?     // Location JSON (lat, lng, accuracy)

  // Status
  status          QuoteStatus @default(PENDING)

  // Timestamps
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model QuoteLine {
  id            String   @id @default(cuid())
  quoteId       String
  quote         Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  productName   String
  description   String?
  quantity      Int
  unitPrice     Decimal
  lineTotal     Decimal  // quantity * unitPrice

  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
}

model ContactRequest {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  createdAt DateTime @default(now())
}

enum QuoteStatus {
  PENDING      // Waiting for review
  SENT         // Quote sent to customer
  VIEWED       // Customer viewed the quote
  SIGNED       // Customer signed
  ACCEPTED     // Work accepted/scheduled
  COMPLETED    // Installation done
  EXPIRED      // Quote expired
  CANCELLED    // Cancelled
}
